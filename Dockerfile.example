# Pioneer Agent — container image
# Binary fetched from the pinned release; workspace + tools mounted from this repo.

FROM debian:bookworm-slim

RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    ca-certificates curl git jq tini libssl3 && \
    rm -rf /var/lib/apt/lists/*

RUN groupadd -g 1001 agent && useradd -u 1001 -g agent -m agent

# Pin a release here. Do NOT commit a binary into this repo.
ARG ZEROCLAW_VERSION=latest
ARG ZEROCLAW_URL=https://github.com/coinmastersguild/pioneer-platform/releases/${ZEROCLAW_VERSION}/download/zeroclaw-linux-amd64
RUN curl -fsSL "$ZEROCLAW_URL" -o /usr/local/bin/zeroclaw && chmod +x /usr/local/bin/zeroclaw

RUN mkdir -p /app/workspace /app/config /app/tools.d && chown -R agent:agent /app

WORKDIR /app

COPY config.toml.example /app/config/config.toml
COPY tools.d/            /app/tools.d/
COPY workspace/          /app/workspace/
COPY entrypoint.sh.example /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh && chown -R agent:agent /app

RUN mkdir -p /home/agent/.zeroclaw && \
    ln -s /app/workspace /home/agent/.zeroclaw/workspace && \
    chown -R agent:agent /home/agent

USER agent
ENV HOME=/home/agent

EXPOSE 18789

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -sf http://localhost:18789/health || exit 1

ENTRYPOINT ["/usr/bin/tini","--"]
CMD ["/app/entrypoint.sh"]
