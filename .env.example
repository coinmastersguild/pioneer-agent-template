# ─── Pioneer Agent Environment ─────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# The real `.env` is gitignored and MUST NEVER be committed.
# In production, Pioneer injects these via the vault — no .env file at all.
# ───────────────────────────────────────────────────────────────────────────

# Pioneer-routed inference (preferred — wallet-authed, no direct provider key)
# Leave ZEROCLAW_API_KEY unset when using pioneer_auth in config.toml.
# ZEROCLAW_API_KEY=sk-pioneer-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Direct provider keys (only if you bypass pioneer_auth — not recommended)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional channel integrations — leave blank to disable
# DISCORD_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# Domain-specific tool APIs (these are yours, not Pioneer's)
# ADMIN_API_KEY=
