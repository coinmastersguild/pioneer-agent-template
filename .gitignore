# Secrets — NEVER commit
.env
.env.*
!.env.example
*.secret
*.key
*.pem
id_rsa*
id_ed25519*

# Runtime state (derivable, ephemeral)
workspace/memory/
workspace/state/
workspace/cron/
workspace/skills/*/state/
workspace/db.sqlite*
workspace/*.sqlite*
workspace/*.db
workspace/*.db-*
workspace/audit.log

# Compiled / fetched binaries (Docker build pulls these — never commit them)
/zeroclaw
/zeroclaw-*
*.exe

# Local build outputs
data/
dist/
build/
*.log

# OS / editor junk
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Pioneer runtime artifacts
.pioneer/
pioneer-agent/
